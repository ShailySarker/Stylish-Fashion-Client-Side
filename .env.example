# ── Backend ────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:5000/api

# ── Firebase (still used for Auth — NOT for Storage upload) ─
VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_PROJECT_ID=
VITE_STORAGE_BUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=

# ── Cloudinary (image uploads — replaces Firebase Storage) ──
# 1. Sign up free at https://cloudinary.com
# 2. Dashboard → Settings → Upload → "Add upload preset"
#    → set Signing Mode to "Unsigned" → save → copy the preset name
# 3. Your Cloud Name is shown on the Cloudinary dashboard home page
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name_here
